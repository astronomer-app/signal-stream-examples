# --- Astronomer Signal Stream ---
ASTRONOMER_SIGNAL_STREAM_KEY=ast_live_...
# Optional: point at a local Astronomer instance during development.
# ASTRONOMER_SIGNAL_STREAM_BASE_URL=http://localhost:4200

# --- Alpaca (paper trading) ---
# Leave both blank to run in dry-run mode: signals are logged, no orders are sent.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Defaults to Alpaca paper trading. Only change this if you mean to trade live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Market data host and options feed used to price the limit order.
# "indicative" is the free (delayed) feed; "opra" is real-time (paid).
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_OPTIONS_FEED=indicative

# --- Example server ---
PORT=8080
ORDER_QUANTITY=1
# How far above the live ask to set the buy limit, as a fraction (0.02 = 2%).
# The order stays marketable but won't chase the price past this cushion.
ORDER_LIMIT_SLIPPAGE=0.02
